# Environment variables for Conversational SHL Assessment Recommender

# Gemini API Key for LLM classification, reranking and conversational responses
# Get one from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# PyTorch/Transformers configuration
USE_TF=NO
USE_TORCH=YES
PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION=python
